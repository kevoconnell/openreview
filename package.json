{
  "name": "openreview",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "openreview": "./dist/cli/openreview.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:viewer",
    "build:viewer": "tsx src/viewer/build-viewer-bundle.ts",
